    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 2},
      "options": {
        "mode": "markdown",
        "content": "## DairyPlant — PackML Overview\n5 ISA-88 units publishing direct MQTT to MonsterMQ → MongoDB → FastAPI → here. Pasteurizer is safety-critical: HTST < 71.5°C trips divert valve → auto-Abort. Inject faults via `Command/Fault/Inject` (see [packml-sim/README.md](/packml-sim/README.md))."
      }
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Receiving Tank-01",
      "gridPos": {"x": 0, "y": 2, "w": 4, "h": 3},
      "datasource": "IDP-API",
      "targets": [{
        "path": "/archive/dairy/latest",
        "method": "GET",
        "params": [["topic", "DairyPlant/Receiving/Tank/Tank-01/Status/StateCurrentStr"]],
        "fields": [
          {"name": "state", "type": "string", "jsonPath": "$.value"}
        ],
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
                  "textMode": "value_and_name", "colorMode": "background"},
      "fieldConfig": {"defaults": {
        "mappings": [
          {"type": "value", "options": {"Execute": {"color": "green", "index": 0}}},
          {"type": "value", "options": {"Idle": {"color": "blue", "index": 1}}},
          {"type": "value", "options": {"Held": {"color": "orange", "index": 2}}},
          {"type": "value", "options": {"Aborted": {"color": "red", "index": 3}}},
          {"type": "value", "options": {"Stopped": {"color": "purple", "index": 4}}}
        ]
      }}
    },

