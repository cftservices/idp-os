      "title": "HTST temperature (°C) — threshold 71.5",
      "gridPos": {"x": 0, "y": 6, "w": 18, "h": 9},
      "datasource": "IDP-API",
      "targets": [{
        "path": "/archive/dairy/history",
        "method": "GET",
        "params": [
          ["topic", "DairyPlant/Process/Pasteurizer/HTST-01/Status/HTST_temp_C"],
          ["minutes", "15"]
        ],
        "fields": [
          {"name": "time", "type": "time", "jsonPath": "$.data[*].time"},
          {"name": "HTST_temp_C", "type": "number", "jsonPath": "$.data[*].value"}
        ],
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {
        "unit": "celsius",
        "min": 60,
        "max": 80,
        "thresholds": {"mode": "absolute", "steps": [
          {"color": "red", "value": null},
          {"color": "green", "value": 71.5}
        ]},
        "custom": {
          "drawStyle": "line",
          "lineInterpolation": "linear",
          "thresholdsStyle": {"mode": "line"},
          "fillOpacity": 10
        }
      }}
    },

