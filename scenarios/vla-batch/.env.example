# ════════════════════════════════════════════════════════════════════════════
# Vla Batch v2 demo — .env (copy to idp-os/.env, then fill in)
# ════════════════════════════════════════════════════════════════════════════
#
# The Vla overlay runs together with the slim-base:
#   docker compose -f docker-compose.slim.yml \
#                  -f scenarios/vla-batch/docker-compose.vla.yml up -d --build
#
# These keys are read by BOTH compose files. Keep them in a single .env in the
# idp-os root (the same file the slim-base / DairyWorks demo already uses).

# ── Domain (Traefik host-routing for the web-facing services) ────────────────
# Dashboard  -> https://milkdemo.${DOMAIN}   (basic-auth gated)
# Grafana    -> https://grafana.${DOMAIN}
DOMAIN=techflow24.com

# Traefik ACME (Let's Encrypt) contact email
TRAEFIK_ACME_EMAIL=your@email.com

# ── MongoDB (store) — slim-base bootstraps root user from these ──────────────
# The slim-base mongo service reads MONGO_INITDB_ROOT_USERNAME / _PASSWORD.
# Keep these in sync with the credentials embedded in MONGO_URL below.
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=example

# ── MongoDB connection (batch-engine + fastapi archive API) ─────────────────
# Contract-locked value. Domain-collections live in db 'idp'
# (vla_batches, vla_recipes, vla_materials, vla_doses, vla_production,
#  vla_samples, vla_events, vla_alarms) + archive collection vla_data.
MONGO_URL=mongodb://root:example@mongo:27017
MONGO_DB=idp

# ── TDengine historian (vla-tdengine + bridge) ──────────────────────────────
# The bridge writes DairyWorks/Vla/# to TDengine db 'idp' via schemaless ILP.
# vla-tdengine is FQDN-sensitive: host = container name = vla-tdengine.
TD_URL=http://vla-tdengine:6041
TD_DB=idp
TD_USER=root
TD_PASS=taosdata

# ── Grafana admin (from slim-base) ──────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ── FastAPI archive API (slim-base) ─────────────────────────────────────────
API_SECRET_KEY=changeme

# ── Dashboard basic-auth for https://milkdemo.${DOMAIN} ─────────────────────
# Generate a bcrypt htpasswd line:
#   htpasswd -nbB demo 'sterk-wachtwoord'
# IMPORTANT: double every $ -> $$ below (docker-compose variable escaping).
# The value below is a DEMO placeholder — replace with a real bcrypt hash.
DASHBOARD_AUTH=demo:$$2y$$05$$replace_with_real_bcrypt_hash
