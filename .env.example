# Domain
DOMAIN=techflow24.com

# Traefik
TRAEFIK_ACME_EMAIL=your@email.com

# RabbitMQ (v3 — replaces MonsterMQ)
RABBITMQ_USER=admin
RABBITMQ_PASS=changeme

# Apache NiFi (v3)
NIFI_USERNAME=admin
NIFI_PASSWORD=changeme-min-12-chars
NIFI_JVM_HEAP_MAX=512m

# MongoDB — v3 (NiFi/N8N write here; was MonsterMQ before)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# Next.js webapp → MongoDB
MONGODB_URI=mongodb://admin:changeme@mongo:27017/idp?authSource=admin
MONGODB_DATABASE=idp

# FastAPI → MongoDB
MONGO_URL=mongodb://admin:changeme@mongo:27017/idp?authSource=admin
MONGO_DB=idp
API_SECRET_KEY=changeme

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# DairyWorks / Milk Production Demo — basic-auth for https://milkdemo.${DOMAIN}
# Generate:  htpasswd -nbB demo 'sterk-wachtwoord'
# IMPORTANT: double every $ -> $$ here (docker-compose escaping).
DASHBOARD_AUTH=demo:$$2y$$05$$replace_with_real_bcrypt_hash
